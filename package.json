{
  "name": "hotel-rincon-backend",
  "version": "1.0.0",
  "description": "Backend for Hotel Rincón del Carmen - JSON Server API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "json-server --watch db.json --port 3000",
    "dev-cors": "json-server --watch db.json --port 3000 --middlewares cors-middleware.js"
  },
  "keywords": ["hotel", "json-server", "api"],
  "author": "Hotel Rincón del Carmen",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
