.lista-container {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 1.5rem;
}
.lista-container h1 {
    text-align: center;
font-family: var(--font-heading);
margin-bottom: 2rem;
}
.reserva-card {
display: flex;
justify-content: space-between;
align-items: center;
background: var(--color-white);
padding: 1.5rem;
border-radius: 8px;
box-shadow: 0 2px 8px rgba(0,0,0,0.1);
margin-bottom: 1rem;
}
.reserva-info h3 {
margin: 0 0 0.5rem 0;
font-family: var(--font-heading);
}
.reserva-actions {
display: flex;
gap: 0.5rem;
}
.reserva-actions button {
padding: 0.5rem 1rem;
border: none;
border-radius: 5px;
cursor: pointer;
color: white;
}
.edit-btn { background-color: var(--color-primary); }
.delete-btn { background-color: #d9534f; }
#edit-modal-overlay {
position: fixed;
top: 0;
left: 0;
width: 100%;
height: 100%;
background: rgba(0,0,0,0.6);
z-index: 1001;
display: flex;
align-items: center;
justify-content: center;
}
#edit-modal {
background: white;
padding: 2rem;
border-radius: 8px;
width: 90%;
max-width: 450px;
}
#edit-form .form-group { display: flex; flex-direction: column; margin-bottom: 1rem; }
#edit-form label { margin-bottom: 0.5rem; }
#edit-form input { padding: 0.8rem; border: 1px solid #ccc; border-radius: 4px; }
.modal-actions { display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1.5rem; }
.modal-actions button[type="submit"] { background-color: var(--color-primary); color: white; border: none; }